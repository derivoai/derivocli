{
  "name": "@derivo/package-manager",
  "version": "0.1.0",
  "description": "Adapter for interacting with npm, pnpm, bun, yarn, pip, cargo, etc.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "dev": "tsc -w"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "devDependencies": {
    "@derivo/config-eslint": "workspace:*",
    "@derivo/config-typescript": "workspace:*"
  }
}
