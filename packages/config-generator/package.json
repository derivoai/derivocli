{
  "name": "@derivo/config-generator",
  "version": "0.1.0",
  "description": "Generates derivo.config.json based on detected stack and prompts",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "dev": "tsc -w"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "devDependencies": {
    "@derivo/config-eslint": "workspace:*",
    "@derivo/config-typescript": "workspace:*"
  }
}
