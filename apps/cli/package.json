{
  "name": "@derivo/cli",
  "version": "0.1.0",
  "description": "Derivo CLI",
  "bin": {
    "derivo": "bin/derivo.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@derivo/cli-core": "workspace:*",
    "@derivo/cli-config": "workspace:*",
    "@derivo/cli-logger": "workspace:*",
    "@derivo/cli-types": "workspace:*",
    "@derivo/cli-utils": "workspace:*",
    "@derivo/terminal-ui": "workspace:*",
    "commander": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@derivo/config-eslint": "workspace:*",
    "@derivo/config-typescript": "workspace:*"
  }
}
