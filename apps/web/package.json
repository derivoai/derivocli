{
  "name": "@derivo/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:action": "vite --config vite.action.config.ts --port=3001 --host=0.0.0.0",
    "build": "vite build",
    "build:action": "vite build --config vite.action.config.ts",
    "build:all": "vite build && vite build --config vite.action.config.ts",
    "preview": "vite preview --port=4000",
    "preview:action": "vite preview --config vite.action.config.ts --port=4001",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@google/genai": "^2.4.0",
    "@react-three/fiber": "^9.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "radix-ui": "^1.6.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.180.0",
    "tw-animate-css": "^1.4.0",
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "@derivo/config-eslint": "workspace:*",
    "@derivo/config-typescript": "workspace:*",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.4.5",
    "vite": "^6.2.3"
  }
}
