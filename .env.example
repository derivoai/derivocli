# ──────────────────────────────────────────────────────────────────────────
# Derivo environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Application URLs ─────────────────────────────────────────────────────────

# APP_URL: Where the web app is hosted (used for CORS / OAuth callbacks).
# Local:      http://localhost:3000
# Production: https://your-web-app.vercel.app
APP_URL="http://localhost:3000"

# PORT: Port the API server listens on (only used when running backend locally).
PORT="3001"

# ── Backend API URL ──────────────────────────────────────────────────────────
# IMPORTANT: When hosting frontend and backend separately on Vercel, set these
# to your backend deployment URL (e.g., https://your-backend.vercel.app).

# VITE_API_URL: Backend API base URL (used by the web app).
# The web frontend will connect to this URL for all API calls.
# Local:      http://localhost:3001
# Production: https://your-backend.vercel.app
VITE_API_URL="http://localhost:3001"

# DERIVO_API_URL: Backend API base URL (used by the CLI).
# The CLI will connect to this URL for all API calls.
# Local:      http://localhost:3001
# Production: https://your-backend.vercel.app
# NOTE: This can also be configured in ~/.derivo/config.json as "apiUrl"
DERIVO_API_URL="http://localhost:3001"

# DERIVO_API_URL: Backend API endpoint used by the CLI (alternative name).
# The CLI checks DERIVO_API_URL first, then falls back to ~/.derivo/config.json,
# then defaults to http://localhost:3001. Set this for production CLI usage.
DERIVO_API_URL="http://localhost:3001"

# ── Firebase Admin (REQUIRED for real auth/subscription enforcement) ─────────
# Without these three, the API runs in MOCK MODE: it accepts any token and
# treats every user as subscribed. Set them to enforce real security.
#
# Get them from: Firebase Console → Project Settings → Service Accounts →
# "Generate new private key". Open the downloaded JSON and copy the values:
#   project_id   -> FIREBASE_PROJECT_ID
#   client_email -> FIREBASE_CLIENT_EMAIL
#   private_key  -> FIREBASE_PRIVATE_KEY  (keep the \n sequences, wrap in quotes)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your...key...\n-----END PRIVATE KEY-----\n"

# ── Better Auth (web/api session auth) ───────────────────────────────────────
# Generate a secret with: openssl rand -hex 32
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# Optional OAuth providers (leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── AI (optional) ────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── Email delivery (Resend) ───────────────────────────────────────────────────
# EMAIL_PROVIDER: set to "resend" to enable real email delivery.
# Leave as "none" in development to skip sending (links logged to stdout only).
EMAIL_PROVIDER="resend"

# RESEND_API_KEY: get from resend.com → API Keys. Required when EMAIL_PROVIDER=resend.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# EMAIL_FROM: verified sender shown to recipients. Must match a domain you've
# verified in your Resend account (resend.com → Domains).
EMAIL_FROM="Derivo <noreply@derivo.in>"

# AUTH_ACTION_URL: the branded Firebase email-action page.
# Every verification / reset link points here — no Firebase console change needed.
AUTH_ACTION_URL="https://auth.derivo.in/action"

# ── Account abuse prevention ──────────────────────────────────────────────────
# MAX_ACCOUNTS_PER_IP: max number of accounts that can be created from a single
# IP within the window. Set to 0 to disable the IP check entirely.
MAX_ACCOUNTS_PER_IP="3"

# MAX_ACCOUNTS_PER_IP_WINDOW_DAYS: sliding window (days) for counting IP
# registrations. Accounts older than this window don't count toward the limit.
MAX_ACCOUNTS_PER_IP_WINDOW_DAYS="30"

# INHERIT_TRIAL_ON_REREGISTER: when true, a user who deletes their account and
# creates a new one with the same email will see their previous trial status
# instead of getting a fresh trial. Set to false to disable (not recommended).
INHERIT_TRIAL_ON_REREGISTER="true"
