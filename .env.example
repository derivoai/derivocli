# ──────────────────────────────────────────────────────────────────────────
# Derivo environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# APP_URL: Where the web app is hosted (used for CORS / OAuth callbacks).
APP_URL="http://localhost:3000"

# PORT: Port the API server listens on (CLI defaults to http://localhost:3001).
PORT="3001"

# ── Firebase Admin (REQUIRED for real auth/subscription enforcement) ─────────
# Without these three, the API runs in MOCK MODE: it accepts any token and
# treats every user as subscribed. Set them to enforce real security.
#
# Get them from: Firebase Console → Project Settings → Service Accounts →
# "Generate new private key". Open the downloaded JSON and copy the values:
#   project_id   -> FIREBASE_PROJECT_ID
#   client_email -> FIREBASE_CLIENT_EMAIL
#   private_key  -> FIREBASE_PRIVATE_KEY  (keep the \n sequences, wrap in quotes)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your...key...\n-----END PRIVATE KEY-----\n"

# ── Better Auth (web/api session auth) ───────────────────────────────────────
# Generate a secret with: openssl rand -hex 32
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# Optional OAuth providers (leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── AI (optional) ────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
